# ================================================================
# CryptoCardNavi — 環境変数テンプレート
# ----------------------------------------------------------------
# このファイルを .env.local にコピーして実際の値を入力してください
# .env.local は .gitignore 済み — コミットしないこと
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
# Supabase ダッシュボード > Settings > API から取得

# Project URL
# SUPABASE_URL=... でも可。コードは両方をフォールバックで読みます。
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Service Role Key (secret — 絶対に公開しないこと)
# Settings > API > Project API keys > service_role
# NEXT_PUBLIC_ 接頭辞をつけてはいけません (client bundle に漏れます)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ── 管理画面パスワード ────────────────────────────────────────────
# デフォルト: admin2026  本番環境では必ず変更してください
# ADMIN_PASSWORD=your-strong-password
