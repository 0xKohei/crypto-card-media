# ================================================================
# CryptoCardNavi — 環境変数テンプレート
# このファイルを .env.local にコピーして実際の値を入力してください
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
# Supabase プロジェクト > Settings > API から取得

# Project URL (どちらか一方でよい。両方書いても問題なし)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co  # サーバー専用の場合はこちら

# Service Role Key (絶対に公開しないこと — NEXT_PUBLIC_ 接頭辞をつけないこと)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 管理画面パスワード ────────────────────────────────────────────
# デフォルト: admin2026
# ADMIN_PASSWORD=your-strong-password
